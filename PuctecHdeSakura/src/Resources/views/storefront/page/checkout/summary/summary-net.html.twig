{% sw_extends '@Storefront/storefront/page/checkout/summary/summary-net.html.twig' %}

{% block page_checkout_summary_net_label %}
	<dt class="col-7 checkout-aside-summary-label summary-net">            	
		{% set grosskundenGroupId = 'checkout.summaryShipping.bigCustomersGroupId'|trans|sw_sanitize %}
		{% if context.customer.groupId is same as(grosskundenGroupId) %}
			{{ 'checkout.summaryNetPrice.bigCustomersText'|trans|sw_sanitize }}
		{% else %}
			{{ 'checkout.summaryNetPrice'|trans|sw_sanitize }}
		{% endif %}
	</dt>
{% endblock %}

